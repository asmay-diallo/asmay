{
  "expo": {
    "name": "Asmay",
    "slug": "Asmayi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/asmay-icon.png",
    "scheme": "asmayi",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#020203",
        "foregroundImage": "./assets/images/asmay-icon.png",
        "backgroundImage": "./assets/images/asmay-backgroundImage.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.asmay25.Asmayi"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/asmay-icon.png"
    },
    
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/asmay-splash-screen.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#ffffff"
          }
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-5524198683293548~6412062690",
          "iosAppId":"ca-app-pub-5524198683293548~4196138488"
        }
      ],
      ["expo-build-properties",
       {
    "android": {
      "compileSdkVersion": 35,
      "targetSdkVersion": 35,
      "minSdkVersion": 24
    }
  }
 ],
      "expo-audio",
      "@stream-io/video-react-native-sdk",
     [ "@config-plugins/react-native-webrtc",
    {
       
          "cameraPermission": "ASMAY réquit votre camera pour accéder à capture en ordre et transmet la vidéo ",
          "microphonePermission": "ASMAY requit votre  microphone pour accéder à capture en ordre  et transmet l'audio"
    
    }]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2aafe30f-32a6-4758-ab63-d778f3639b6d"
      }
    }
  }
}
